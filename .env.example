# Local Agent Stack - Environment Configuration Template
# Copy this to .env and customize for your setup

# ============================================================================
# LOCAL INFERENCE SERVER
# ============================================================================

# Server bind host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
LOCAL_SERVER_HOST=0.0.0.0

# Server port
LOCAL_SERVER_PORT=8000

# ============================================================================
# OLLAMA BACKEND CONFIGURATION
# ============================================================================

# Ollama server endpoint
OLLAMA_HOST=http://127.0.0.1:11434

# Model to use (see: ollama list)
# Options: mistral, neural-chat, dolphin-mixtral, llama2, openhermes, etc.
OLLAMA_MODEL=mistral:latest

# ============================================================================
# HYBRID ROUTER CONFIGURATION
# ============================================================================

# Prefer local inference (true) or cloud (false)
PREFER_LOCAL=true

# Complexity threshold for routing (1-10)
# Tasks below this score route to local, above route to cloud
LOCAL_COMPLEXITY_THRESHOLD=3

# ============================================================================
# CLOUD API (OPTIONAL - for fallback/cloud routing)
# ============================================================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# Leave empty to disable cloud fallback
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API base URL (usually don't change)
OPENAI_API_BASE=https://api.openai.com/v1

# Cloud model to use for complex tasks
CLOUD_MODEL=gpt-3.5-turbo

# ============================================================================
# RAG CONFIGURATION
# ============================================================================

# ChromaDB collection name
CHROMA_COLLECTION_NAME=local_agent_docs

# Embedding model for RAG retrieval
# Options: all-MiniLM-L6-v2 (fast, small), all-mpnet-base-v2 (better quality)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Set to DEBUG for verbose logging
LOG_LEVEL=INFO
